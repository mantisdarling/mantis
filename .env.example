# MANTIS Environment Variables Placeholder

# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mantis?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Auth
JWT_SECRET="your-jwt-secret-placeholder"
JWT_EXPIRES_IN="7d"

# Google Calendar (OAuth)
GOOGLE_CLIENT_ID="placeholder-client-id"
GOOGLE_CLIENT_SECRET="placeholder-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Stripe
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"

# WebRTC (TURN/STUN fallbacks - e.g., Twilio)
TWILIO_ACCOUNT_SID="placeholder-account-sid"
TWILIO_AUTH_TOKEN="placeholder-auth-token"

# External Microservices
ML_SERVICE_URL="http://localhost:8000"
